#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
info()  { echo -e "${GREEN}[INFO]${NC}  $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
die()   { echo -e "${RED}[FAIL]${NC}  $*" >&2; exit 1; }

CUDA_ARCH="12.0"
TORCH_CUDA_ARCH="12.0"
CUDA_HOME="${CUDA_HOME:-/usr/local/cuda}"
INSTALL_DIR="${HOME}/mirage_workspace"
VENV_DIR="${INSTALL_DIR}/venv"
MODEL_ID="Qwen/Qwen3.5-0.8B"
HF_CACHE="${HOME}/.cache/huggingface"

info "Checking prerequisites..."

[[ -f "${CUDA_HOME}/bin/nvcc" ]] || die "nvcc not found at ${CUDA_HOME}/bin/nvcc. Install CUDA Toolkit 12.8+."

CUDA_VER=$("${CUDA_HOME}/bin/nvcc" --version | grep -oP 'release \K[0-9]+\.[0-9]+')
CUDA_MAJOR=$(echo "$CUDA_VER" | cut -d. -f1)
CUDA_MINOR=$(echo "$CUDA_VER" | cut -d. -f2)
[[ "$CUDA_MAJOR" -gt 12 || ( "$CUDA_MAJOR" -eq 12 && "$CUDA_MINOR" -ge 8 ) ]] \
  || die "CUDA ${CUDA_VER} too old. Need 12.8+ for sm_120."
info "CUDA ${CUDA_VER} — OK"

DRIVER_VER=$(nvidia-smi --query-gpu=driver_version --format=csv,noheader 2>/dev/null | head -1) \
  || die "nvidia-smi failed — is the NVIDIA driver installed?"
DRIVER_MAJOR=$(echo "$DRIVER_VER" | cut -d. -f1)
[[ "$DRIVER_MAJOR" -ge 570 ]] \
  || die "Driver ${DRIVER_VER} too old. Blackwell needs >= 570."
info "Driver ${DRIVER_VER} — OK"

GPU_NAME=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1)
info "GPU: ${GPU_NAME}"

# Get SM count via Python/torch instead of nvidia-smi
info "MPI not checked yet — will install below if missing."

PYTHON="/usr/bin/python3.12"
[[ -x "$PYTHON" ]] || die "Python 3.12 not found at ${PYTHON}"
PY_VER=$("$PYTHON" --version)
info "${PY_VER} at ${PYTHON}"

# Build tools — install MPI automatically if missing
for tool in git cmake ninja; do
  command -v "$tool" &>/dev/null || die "'$tool' not found. Run: sudo apt install git cmake ninja-build"
done

if ! command -v mpicc &>/dev/null; then
  warn "mpicc not found — installing OpenMPI..."
  sudo apt-get install -y openmpi-bin libopenmpi-dev \
    || die "Failed to install OpenMPI. Run manually: sudo apt install openmpi-bin libopenmpi-dev"
  info "OpenMPI installed."
fi
info "All build tools present."

info "Creating workspace at ${INSTALL_DIR}..."
mkdir -p "${INSTALL_DIR}"
cd "${INSTALL_DIR}"

if [[ ! -d "${VENV_DIR}" ]]; then
  info "Creating virtualenv..."
  "$PYTHON" -m venv "${VENV_DIR}"
fi
source "${VENV_DIR}/bin/activate"
pip install --upgrade pip wheel setuptools packaging

info "Installing PyTorch 2.9.0+cu128..."
pip install torch==2.9.0 torchvision torchaudio \
  --index-url https://download.pytorch.org/whl/cu128

# Verify sm_120 visible and grab SM count
SM_COUNT=$("${VENV_DIR}/bin/python" - <<'PYCHECK'
import torch, sys
assert torch.cuda.is_available(), "CUDA not available to PyTorch"
cc = torch.cuda.get_device_capability()
assert cc >= (12, 0), f"Expected sm_120+, got sm_{cc[0]}{cc[1]}"
props = torch.cuda.get_device_properties(0)
print(props.multi_processor_count)
PYCHECK
) || die "PyTorch CUDA check failed — sm_120 not visible."
info "PyTorch sm_120 OK | ${SM_COUNT} SMs detected"

pip install \
  "transformers>=4.51" \
  huggingface_hub \
  accelerate \
  triton \
  numpy \
  sentencepiece \
  protobuf

# flash-attn separate — may fail on sm_120, non-fatal
info "Attempting flash-attn install (non-fatal if it fails)..."
pip install flash-attn --no-build-isolation 2>&1 || warn "flash-attn failed — continuing without it."

if [[ ! -d "${INSTALL_DIR}/mirage" ]]; then
  info "Cloning Mirage (mpk branch)..."
  git clone --recursive --branch mpk \
    https://github.com/mirage-project/mirage \
    "${INSTALL_DIR}/mirage"
else
  info "Mirage already cloned — pulling latest..."
  cd "${INSTALL_DIR}/mirage"
  git pull --recurse-submodules
  cd "${INSTALL_DIR}"
fi

cd "${INSTALL_DIR}/mirage"

info "Patching CUTLASS CMakeLists for sm_120..."
CUTLASS_CMAKE="${INSTALL_DIR}/mirage/deps/cutlass/CMakeLists.txt"
if [[ -f "$CUTLASS_CMAKE" ]]; then
  if grep -q "CUTLASS_NVCC_ARCHS" "$CUTLASS_CMAKE"; then
    sed -i 's/\(CUTLASS_NVCC_ARCHS "[^"]*\)"/\1;120"/' "$CUTLASS_CMAKE"
    info "CUTLASS patched."
  else
    warn "CUTLASS_NVCC_ARCHS not found in CMakeLists — patch skipped."
  fi
else
  warn "CUTLASS CMakeLists not at expected path — skipping patch."
fi

info "Building Mirage (10–25 min)..."
export CUDA_HOME="${CUDA_HOME}"
export TORCH_CUDA_ARCH_LIST="${TORCH_CUDA_ARCH}"
export CUTLASS_NVCC_ARCHS="80;86;89;90;120"
export CMAKE_CUDA_ARCHITECTURES="80;86;89;90;120"
export MAX_JOBS="${MAX_JOBS:-$(nproc)}"

pip install -e . -v 2>&1 | tee "${INSTALL_DIR}/mirage_build.log" \
  || die "Mirage build failed. Check ${INSTALL_DIR}/mirage_build.log"

"${VENV_DIR}/bin/python" -c "import mirage; print('  mirage imported OK')" \
  || die "Mirage import failed — check ${INSTALL_DIR}/mirage_build.log"
info "Mirage installed."

info "Downloading ${MODEL_ID}..."
"${VENV_DIR}/bin/python" - <<PYDOWNLOAD
from huggingface_hub import snapshot_download
snapshot_download(
    repo_id="${MODEL_ID}",
    cache_dir="${HF_CACHE}",
    ignore_patterns=["*.gguf", "*.bin"],
)
print("  Model downloaded.")
PYDOWNLOAD

info "Writing inference script..."
cat > "${INSTALL_DIR}/run_qwen_mpk.py" << PYEOF
"""
run_qwen_mpk.py — Qwen3.5-0.8B with Mirage MPK on RTX 5060 (sm_120).
Falls back to HF eager if MPK compile fails.
"""

import argparse, sys, time, torch
from transformers import AutoModelForCausalLM, AutoTokenizer

MODEL_ID = "Qwen/Qwen3.5-0.8B"

def get_sm_config(num_sms: int) -> dict:
    # Reserve 4 SMs for schedulers (16 logical / 4 = 4 physical SMs)
    num_local_schedulers = 16
    num_workers = num_sms - 4
    assert num_workers > 0
    return {"num_workers": num_workers, "num_local_schedulers": num_local_schedulers}

def load_model(device="cuda"):
    print(f"[init] Loading {MODEL_ID}...")
    tok = AutoTokenizer.from_pretrained(MODEL_ID, trust_remote_code=True)
    mdl = AutoModelForCausalLM.from_pretrained(
        MODEL_ID, torch_dtype=torch.bfloat16, device_map=device, trust_remote_code=True
    )
    mdl.eval()
    return mdl, tok

def run_mpk(model, tokenizer, prompt, max_new_tokens=128):
    try:
        import mirage as mi
    except ImportError:
        print("[mpk] Mirage not importable — falling back.", file=sys.stderr)
        return None

    num_sms = torch.cuda.get_device_properties(0).multi_processor_count
    sm_cfg  = get_sm_config(num_sms)
    print(f"[mpk] {torch.cuda.get_device_name(0)} | {num_sms} SMs | workers={sm_cfg['num_workers']}")

    step   = torch.zeros(1, dtype=torch.int32, device="cuda")
    tokens = torch.zeros(1, max_new_tokens + 64, dtype=torch.int64, device="cuda")

    try:
        mpk = mi.PersistentKernel(
            world_size=1, mpi_rank=0,
            num_workers=sm_cfg["num_workers"],
            num_local_schedulers=sm_cfg["num_local_schedulers"],
            num_remote_schedulers=0,
            meta_tensors=[step, tokens],
            profiler_tensor=None,
        )
        for i, layer in enumerate(model.model.layers):
            mpk.attach_input(layer.input_layernorm.weight,          name=f"input_norm_{i}")
            mpk.attach_input(layer.post_attention_layernorm.weight,  name=f"post_attn_norm_{i}")
            mpk.attach_input(layer.self_attn.q_proj.weight,         name=f"q_{i}")
            mpk.attach_input(layer.self_attn.k_proj.weight,         name=f"k_{i}")
            mpk.attach_input(layer.self_attn.v_proj.weight,         name=f"v_{i}")
            mpk.attach_input(layer.self_attn.o_proj.weight,         name=f"o_{i}")
            mpk.attach_input(layer.mlp.gate_proj.weight,            name=f"gate_{i}")
            mpk.attach_input(layer.mlp.up_proj.weight,              name=f"up_{i}")
            mpk.attach_input(layer.mlp.down_proj.weight,            name=f"down_{i}")
        mpk.attach_input(model.model.norm.weight,   name="final_norm")
        mpk.attach_input(model.lm_head.weight,      name="lm_head")
        mpk.compile()
        print("[mpk] Compiled OK.")
    except Exception as exc:
        print(f"[mpk] Compile failed: {exc}", file=sys.stderr)
        return None

    input_ids = tokenizer.encode(prompt, return_tensors="pt").cuda()
    seq_len   = input_ids.shape[1]
    tokens[0, :seq_len] = input_ids[0]
    step[0] = seq_len

    generated = input_ids[0].tolist()
    t0 = time.perf_counter()
    for _ in range(max_new_tokens):
        nxt = mpk.run()
        tok = int(nxt.item()) if hasattr(nxt, "item") else int(nxt)
        generated.append(tok)
        if tok == tokenizer.eos_token_id:
            break
        cur = int(step[0].item())
        if cur < tokens.shape[1]:
            tokens[0, cur] = tok
        step[0] = cur + 1

    elapsed = time.perf_counter() - t0
    n_gen   = len(generated) - seq_len
    print(f"[mpk] {n_gen} tok | {elapsed:.2f}s | {n_gen/elapsed:.1f} tok/s")
    return tokenizer.decode(generated, skip_special_tokens=True)

def run_eager(model, tokenizer, prompt, max_new_tokens=128):
    print("[eager] Running HF generate...")
    ids = tokenizer.encode(prompt, return_tensors="pt").cuda()
    t0  = time.perf_counter()
    with torch.no_grad():
        out = model.generate(ids, max_new_tokens=max_new_tokens, do_sample=False)
    elapsed = time.perf_counter() - t0
    n_gen   = out.shape[1] - ids.shape[1]
    print(f"[eager] {n_gen} tok | {elapsed:.2f}s | {n_gen/elapsed:.1f} tok/s")
    return tokenizer.decode(out[0], skip_special_tokens=True)

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--prompt",     default="Explain transformer neural networks simply.")
    ap.add_argument("--max-tokens", type=int, default=128)
    ap.add_argument("--no-mpk",     action="store_true")
    args = ap.parse_args()

    assert torch.cuda.is_available(), "No CUDA device"
    cc = torch.cuda.get_device_capability()
    print(f"[init] {torch.cuda.get_device_name(0)} (sm_{cc[0]}{cc[1]})")

    model, tokenizer = load_model()
    result = None
    if not args.no_mpk:
        result = run_mpk(model, tokenizer, args.prompt, args.max_tokens)
    if result is None:
        result = run_eager(model, tokenizer, args.prompt, args.max_tokens)
    print("\n" + "=" * 60)
    print(result)

if __name__ == "__main__":
    main()
PYEOF

chmod +x "${INSTALL_DIR}/run_qwen_mpk.py"

echo ""
info "═══════════════════════════════════════════════════════"
info "Done! CUDA 13.2 detected — using cu128 torch wheels."
info ""
info "Activate:  source ${VENV_DIR}/bin/activate"
info "Run MPK:   python ${INSTALL_DIR}/run_qwen_mpk.py"
info "Run eager: python ${INSTALL_DIR}/run_qwen_mpk.py --no-mpk"
info "═══════════════════════════════════════════════════════"